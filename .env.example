# Database
DATABASE_URL=postgresql://localhost:5432/hackathon_db
MONGODB_URI=mongodb://localhost:27017/hackathon

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
